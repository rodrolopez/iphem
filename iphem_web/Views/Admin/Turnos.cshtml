@model IEnumerable<iphem_web.Models.Turno>

@{
    ViewData["Title"] = "Gestión de Turnos";
    Layout = "_Layout"; // Usamos el layout general por ahora
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-iphem" style="font-weight: bold;"><i class="bi bi-calendar-check me-2"></i>Gestión de Turnos</h2>
    </div>

    @if (ViewBag.FiltroActivo != null)
    {
        <div class="alert alert-info py-2 mb-3 d-flex justify-content-between align-items-center shadow-sm border-0 border-start border-info border-4">
            <span><i class="bi bi-calendar-event me-2"></i><strong>@ViewBag.FiltroActivo</strong></span>
            <a asp-action="Turnos" class="btn btn-sm btn-outline-info text-dark fw-bold">Ver todos los turnos</a>
        </div>
    }

    <div class="bg-light p-3 rounded border shadow-sm mb-4">
        <form asp-action="Turnos" method="get" class="row g-2 align-items-center">

            @if (!string.IsNullOrEmpty(Context.Request.Query["filtro"]))
            {
                <input type="hidden" name="filtro" value="@Context.Request.Query["filtro"]" />
            }

            <div class="col-md-6 col-lg-5">
                <div class="input-group">
                    <input type="text" name="busqueda" class="form-control border-secondary"
                           placeholder="Buscar por DNI o Apellido..."
                           value="@ViewData["BusquedaActual"]">
                    <button class="btn btn-secondary" type="submit">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                    @if (ViewData["BusquedaActual"] != null)
                    {
                        <a asp-action="Turnos" class="btn btn-outline-danger" title="Limpiar búsqueda">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </div>

            <div class="col-md-1 col-lg-3"></div>

            <div class="col-md-5 col-lg-4 d-flex justify-content-md-end align-items-center">
                <label class="me-2 text-muted small fw-bold text-nowrap mb-0"><i class="bi bi-sort-down me-1"></i>Ordenar:</label>
                <select name="orden" class="form-select border-secondary fw-bold text-dark" style="cursor: pointer;" onchange="this.form.submit()">
                    @if (ViewBag.OrdenActual == "fecha_turno")
                    {
                        <option value="recientes">Últimos solicitados</option>
                        <option value="fecha_turno" selected>Por fecha de cita (Agenda)</option>
                    }
                    else
                    {
                        <option value="recientes" selected>Últimos solicitados</option>
                        <option value="fecha_turno">Por fecha de cita (Agenda)</option>
                    }
                </select>
            </div>
        </form>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="bg-iphem text-white">
                    <tr>
                        <th>Cita</th>
                        <th>Solicitante</th>
                        <th>DNI</th>
                        <th>Donación para...</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td>
                                <div class="fw-bold fs-6 text-dark">@item.Fechahora.ToString("dd/MM HH:mm")</div>
                                <small class="text-muted" title="Momento en que se registró en el sistema">
                                    <i class="bi bi-clock-history me-1"></i>Pedido el: @(item.FechaCreacion.Year > 2000 ? item.FechaCreacion.ToLocalTime().ToString("dd/MM HH:mm") : "-")
                                </small>
                            </td>
                            <td>
                                <div class="fw-bold">@item.Nombresolicitante @item.Apellidosolicitante</div>
                                <small class="text-muted"><i class="bi bi-telephone me-1"></i>@item.Telefonosolicitante</small>
                            </td>
                            <td><code class="text-dark fs-6">@item.Dnisolicitante</code></td>
                            <td>
                                @if (string.IsNullOrEmpty(item.Pacientedestino))
                                {
                                    <span class="badge bg-info text-dark border border-info"><i class="bi bi-droplet-fill text-danger me-1"></i>Voluntario</span>
                                }
                                else
                                {
                                    <span class="text-dark fw-bold"><i class="bi bi-person-heart text-danger me-1"></i>@item.Pacientedestino</span>
                                }
                            </td>
                            <td><span class="badge bg-light text-secondary border">@item.IdtipoturnoNavigation?.Nombre</span></td>
                            <td>
                                @if(item.IdestadoturnoNavigation?.Nombre == "Pendiente")
                                {
                                    <span class="badge bg-warning text-dark w-100">Pendiente</span>
                                }
                                else if(item.IdestadoturnoNavigation?.Nombre == "Confirmado")
                                {
                                    <span class="badge bg-success w-100">Confirmado</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary w-100">@item.IdestadoturnoNavigation?.Nombre</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square"></i> Gestionar
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="mt-4">
        <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">
            <i class="bi bi-arrow-left"></i> Volver al Dashboard
        </a>
    </div>
</div>