@model IEnumerable<iphem_web.Models.Noticia>

@{
    ViewData["Title"] = "Gestión de Noticias";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-iphem fw-bold">Noticias del Portal</h2>
        <a asp-action="NuevaNoticia" class="btn btn-iphem">
            <i class="bi bi-plus-lg"></i> Redactar Nueva
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title text-iphem fw-bold">@item.Titulo</h5>
                            <small class="text-muted">@item.Fechapublicacion?.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <h6 class="card-subtitle mb-2 text-muted">@item.Epigrafe</h6>
                        <p class="card-text text-truncate">@item.Cuerpo</p>
                        
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="EditarNoticia" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <a asp-action="BorrarNoticia" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Estás seguro de que querés borrar esta noticia?');">
                                <i class="bi bi-trash"></i> Eliminar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
        
        @if (!Model.Any())
        {
            <div class="alert alert-warning text-center">
                No hay noticias publicadas. ¡Escribí la primera!
            </div>
        }
    </div>
    
    <div class="mt-4">
        <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">
            <i class="bi bi-arrow-left"></i> Volver al Dashboard
        </a>
    </div>
</div>