@model IEnumerable<iphem_web.Models.Carrusel>
@{ ViewData["Title"] = "Gestión Carrusel"; }

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Gestión de Banners</h2>
            <p class="text-muted small">Imágenes del carrusel principal.</p>
        </div>
        <a asp-action="NuevoItemCarrusel" class="btn btn-iphem shadow-sm">
            <i class="bi bi-plus-lg"></i> Nueva Imagen
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model) {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    
                    <div class="position-relative">
                        <img src="~/img/carrusel/@item.ImagenPath" class="card-img-top" 
                             style="height: 160px; object-fit: cover; opacity: @(item.Activo == true ? "1" : "0.5");">
                        
                        @if (item.Activo == true)
                        {
                            <span class="position-absolute top-0 end-0 badge bg-success m-2 shadow">ACTIVO</span>
                        }
                        else
                        {
                            <span class="position-absolute top-0 end-0 badge bg-secondary m-2 shadow">OCULTO</span>
                        }
                    </div>

                    <div class="card-body">
                        <p class="card-text text-muted small text-truncate mb-3">
                            <i class="bi bi-link-45deg fs-5 align-middle"></i> 
                            @(string.IsNullOrEmpty(item.Enlace) ? "Sin enlace de redirección" : item.Enlace)
                        </p>

                        <div class="d-grid gap-2">
                            <a asp-action="EditarItemCarrusel" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil-square"></i> Editar / Ocultar
                            </a>
                            
                            <a asp-action="BorrarItemCarrusel" asp-route-id="@item.Id" 
                               class="btn btn-outline-danger btn-sm" 
                               onclick="return confirm('¿Estás seguro de que querés eliminar esta imagen permanentemente?');">
                                <i class="bi bi-trash"></i> Eliminar
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
        
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 bg-light rounded">
                <p class="text-muted mb-0">No hay imágenes cargadas en el carrusel.</p>
            </div>
        }
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">
            <i class="bi bi-arrow-left"></i> Volver al Panel de Administracion
        </a>
    </div>
</div>