@model iphem_web.Models.Carrusel

@{
    ViewData["Title"] = "Editar Banner";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0 fw-bold">Editar Banner</h4>
                </div>
                <div class="card-body">
                    <form asp-action="EditarItemCarrusel" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImagenPath" /> <div class="mb-3 text-center p-3 bg-light rounded border">
                            <label class="d-block mb-2 text-muted small fw-bold">IMAGEN ACTUAL</label>
                            @if (!string.IsNullOrEmpty(Model.ImagenPath))
                            {
                                <img src="~/img/carrusel/@Model.ImagenPath" class="img-fluid rounded shadow-sm" style="max-height: 150px;">
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Cambiar Imagen (Opcional)</label>
                            <input type="file" name="archivoImagen" class="form-control" accept="image/*" />
                            <small class="text-muted">Si no subís nada, queda la foto actual.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Enlace de Redirección</label>
                            <input asp-for="Enlace" class="form-control" placeholder="Ej: https://..." />
                        </div>

                        <div class="form-check form-switch mb-4 p-3 border rounded bg-light">
                            <input class="form-check-input ms-0 me-3" type="checkbox" asp-for="Activo" style="transform: scale(1.3);">
                            <label class="form-check-label fw-bold text-dark ps-2">
                                Mostrar en el Inicio
                            </label>
                            <div class="form-text mt-2 ps-2">
                                Si desactivás esto, la imagen se guarda pero no aparece en la web.
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold">Guardar Cambios</button>
                            <a asp-action="Carrusel" class="btn btn-link text-secondary text-decoration-none">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>