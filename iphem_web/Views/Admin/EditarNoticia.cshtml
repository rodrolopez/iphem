@model iphem_web.Models.Noticia
@{ ViewData["Title"] = "Editar Noticia"; }

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Editar Noticia</h4>
                </div>
                <div class="card-body">
                    <form asp-action="EditarNoticia" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Fechapublicacion" />
                        <input type="hidden" asp-for="Idusuariocreador" />
                        <input type="hidden" asp-for="ImagenPath" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Título</label>
                            <input asp-for="Titulo" class="form-control" required />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Epígrafe</label>
                            <input asp-for="Epigrafe" class="form-control" />
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ImagenPath))
                        {
                            <div class="mb-3 p-3 bg-light border text-center">
                                <p class="small text-muted mb-2">Imagen Actual:</p>
                                <img src="~/img/noticias/@Model.ImagenPath" style="max-height: 150px;" class="rounded shadow-sm">
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-bold">Cambiar Imagen (Opcional)</label>
                            <input type="file" name="archivoImagen" class="form-control" accept="image/*" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Cuerpo</label>
                            <textarea asp-for="Cuerpo" class="form-control" rows="8"></textarea>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Noticias" class="btn btn-secondary me-md-2">Cancelar</a>
                            <button type="submit" class="btn btn-warning">Guardar Cambios</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>