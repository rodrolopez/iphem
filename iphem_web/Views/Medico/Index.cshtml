@{
    ViewData["Title"] = "Panel Médico";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h3 class="fw-bold text-dark"><i class="bi bi-heart-pulse-fill text-danger me-2"></i>Portal de Profesionales de la Salud</h3>
            <p class="text-muted">Sistema de evaluación de donantes y carga de resultados.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100 border-start border-4 border-warning">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0">Evaluación de Cuestionarios</h5>
                        <i class="bi bi-clipboard2-pulse fs-3 text-warning"></i>
                    </div>
                    <p class="text-muted small">Revisá las declaraciones juradas de los donantes antes de la extracción.</p>

                    @if (ViewBag.TriagesPendientes > 0)
                    {
                        <div class="alert alert-warning py-2 mb-3">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> Tenés <strong>@ViewBag.TriagesPendientes</strong> formularios esperando tu evaluación.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light border py-2 mb-3 text-muted">
                            <i class="bi bi-check-circle me-2"></i> No hay cuestionarios pendientes.
                        </div>
                    }

                    <a asp-action="TriagesPendientes" class="btn btn-warning fw-bold w-100">
                        Ir a la Bandeja de Cuestionarios
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm border-0 h-100 border-start border-4 border-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0">Resultados de Laboratorio</h5>
                            <i class="bi bi-file-earmark-medical fs-3 text-info"></i>
                        </div>
                        <p class="text-muted small">Cargá los archivos PDF con los resultados serológicos de los donantes que ya realizaron la extracción.</p>

                        <a asp-controller="Medico" asp-action="CargaResultados" class="btn btn-outline-info fw-bold w-100 mt-4 border-2">
                            <i class="bi bi-cloud-arrow-up me-1"></i> Ir a Carga de Resultados
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>