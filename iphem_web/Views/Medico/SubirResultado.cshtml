@model iphem_web.Models.Turno

@{
ViewData["Title"] = "Subir Resultado de Laboratorio";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-cloud-arrow-up me-2"></i>Cargar Resultado Clínico</h5>
                    <span class="badge bg-light text-dark shadow-sm">Turno #@Model.Id</span>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="bg-light p-3 rounded mb-4 border-start border-4 border-secondary">
                        <div class="row">
                            <div class="col-sm-6">
                                <p class="mb-1 text-muted small">Paciente / Donante</p>
                                <p class="mb-1 fw-bold fs-5">@Model.UsuarioNavigation?.Nombrecompleto</p>
                                <p class="mb-0"><i class="bi bi-person-vcard me-2"></i>DNI: @Model.Dnisolicitante</p>
                            </div>
                            <div class="col-sm-6 border-start border-2">
                                <p class="mb-1 text-muted small">Detalles de la Extracción</p>
                                <p class="mb-1"><i class="bi bi-calendar-event me-2"></i>@Model.Fechahora.ToString("dd 'de' MMMM, yyyy")</p>
                                <p class="mb-0"><i class="bi bi-droplet-half me-2"></i>@Model.IdtipoturnoNavigation?.Nombre</p>
                            </div>
                        </div>
                    </div>

                    @if (TempData["MensajeError"] != null)
                    {
                    <div class="alert alert-danger"><i class="bi bi-x-circle-fill me-2"></i>@TempData["MensajeError"]</div>
                    }

                    <form asp-action="SubirResultado" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Archivo de Laboratorio (Solo PDF)</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white text-danger"><i class="bi bi-filetype-pdf fs-5"></i></span>
                                <input type="file" name="archivoPdf" class="form-control form-control-lg" accept="application/pdf" required />
                            </div>
                            <div class="form-text text-muted"><i class="bi bi-info-circle me-1"></i>El documento será visible en el portal privado del donante.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Notas Médicas (Opcional)</label>
                            <textarea name="notasLaboratorio" class="form-control shadow-sm" rows="3" placeholder="Ej: Serología no reactiva. Apto para futuras donaciones."></textarea>
                            <div class="form-text">Estas notas acompañarán al archivo PDF al momento de la descarga.</div>
                        </div>

                        <hr class="text-muted opacity-25 my-4" />

                        <div class="d-flex justify-content-end gap-3">
                            <a asp-action="CargaResultados" class="btn btn-outline-secondary px-4 fw-bold">
                                <i class="bi bi-arrow-left me-1"></i> Volver
                            </a>
                            <button type="submit" class="btn btn-info px-4 fw-bold text-white shadow-sm">
                                <i class="bi bi-cloud-upload me-1"></i> Guardar y Notificar
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>