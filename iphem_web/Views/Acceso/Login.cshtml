@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-iphem text-white text-center py-4">
                    <h2 class="mb-0"><i class="bi bi-droplet-fill"></i> IPHEM</h2>
                    <p class="mb-0 small">Acceso al Sistema de Gestión y Portal de Donantes</p>
                </div>

                <div class="card-body p-5">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger text-center mb-4">
                            <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                        </div>
                    }

                    <form asp-action="Login" method="post" autocomplete="off">
                        <div class="mb-4">
                            <label class="form-label text-muted">Usuario</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-person-badge"></i></span>
                                <input type="text" name="identificador" class="form-control" placeholder="Usuario..." required autocomplete="off" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted">Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-key"></i></span>
                                <input type="password" name="password" class="form-control" placeholder="••••••••" autocomplete="off" required />
                            </div>
                            <div class="form-text mt-2"><i class="bi bi-info-circle me-1"></i>Si es tu primer ingreso, tu clave es tu número de DNI.</div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-iphem btn-lg fw-bold">Ingresar</button>
                        </div>
                    </form>
                </div>

                <div class="card-footer text-center bg-light py-3">
                    <small class="text-muted">¿Olvidaste tu clave? <a href="#" class="text-iphem text-decoration-none fw-bold">Recuperarla aquí</a></small>
                </div>
            </div>
        </div>
    </div>
</div>