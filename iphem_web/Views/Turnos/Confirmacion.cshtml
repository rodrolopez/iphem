@model iphem_web.Models.Turno
@{ ViewData["Title"] = "Turno Confirmado"; }

<div class="container mt-5 text-center">
    <div class="card shadow border-0 mx-auto" style="max-width: 600px;">
        <div class="card-body p-5">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
            </div>
            
            <h2 class="fw-bold text-iphem">¡Solicitud Enviada!</h2>
            <p class="lead text-muted">Tu solicitud de turno ha sido registrada correctamente.</p>
            
            <div class="alert alert-light border mt-4">
                <h5>Nro. de Solicitud: <strong class="fs-3">#@Model.Id</strong></h5>
                <p class="mb-0">Guardá este número para consultar el estado.</p>
            </div>

            <ul class="list-group list-group-flush text-start mt-4">
                <li class="list-group-item"><strong>Nombre:</strong> @Model.Nombresolicitante @Model.Apellidosolicitante</li>
                <li class="list-group-item"><strong>Fecha solicitada:</strong> @Model.Fechahora.ToString("dd/MM/yyyy HH:mm")</li>
                <li class="list-group-item"><strong>Tipo:</strong> @Model.IdtipoturnoNavigation?.Nombre</li>
            </ul>

            <div class="mt-5">
                <a asp-controller="Home" asp-action="Index" class="btn btn-iphem px-4">Volver al Inicio</a>
            </div>
            
            <p class="small text-muted mt-3">
                El estado actual es <strong>Pendiente</strong>. Recibirás una confirmación telefónica o por email.
            </p>
        </div>
    </div>
</div>