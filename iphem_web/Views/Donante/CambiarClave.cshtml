@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-iphem text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Seguridad de la Cuenta</h5>
                </div>

                <div class="card-body p-4">
                    <p class="text-muted mb-4">Te recomendamos elegir una contraseña segura que no uses en otros sitios.</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
                        </div>
                    }

                    <form asp-action="CambiarClave" method="post" autocomplete="off">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Contraseña Actual</label>
                            <input type="password" name="claveActual" class="form-control" placeholder="Ingresá tu clave actual (o tu DNI si es tu primer ingreso)" required />
                        </div>

                        <hr class="text-muted my-4" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nueva Contraseña</label>
                            <input type="password" name="nuevaClave" class="form-control" placeholder="Mínimo 6 caracteres" minlength="6" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Confirmar Nueva Contraseña</label>
                            <input type="password" name="confirmarClave" class="form-control" placeholder="Repetí la nueva clave" minlength="6" required />
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-4 pt-2 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold d-flex align-items-center">
                                <i class="bi bi-x-circle me-2"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-iphem px-4 fw-bold d-flex align-items-center">
                                <i class="bi bi-check2-circle me-2"></i>Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>