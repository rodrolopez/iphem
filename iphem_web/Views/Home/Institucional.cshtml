@{ ViewData["Title"] = "Institucional"; }

<div class="bg-iphem py-5 text-white mb-5">
    <div class="container text-center">
        <h1 class="display-5 fw-bold">Nuestra Institución</h1>
        <p class="lead col-md-8 mx-auto">Conocé quiénes somos y nuestro compromiso con la salud pública de San Juan.</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row align-items-center mb-5">
        
        <div class="col-md-4 text-center mb-4 mb-md-0">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <div class="mx-auto rounded-circle bg-white d-flex align-items-center justify-content-center shadow-sm" 
                             style="width: 150px; height: 150px; overflow: hidden;">
                             <i class="bi bi-person-fill text-secondary" style="font-size: 5rem;"></i>
                            
                            </div>
                    </div>
                    
                    <h4 class="text-iphem fw-bold mb-0">Dra. Rosario Roca</h4>
                    <p class="text-muted fw-bold text-uppercase small mb-3">Directora Ejecutiva</p>
                    <hr class="mx-auto" style="width: 50px; border-top: 3px solid var(--sj-naranja);">
                    
                    <p class="small text-muted fst-italic">
                        "Trabajamos día a día para garantizar sangre segura para cada sanjuanino que la necesite, promoviendo la donación voluntaria y habitual."
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-8 ps-md-5">
            <h2 class="text-iphem fw-bold mb-4">El IPHEM</h2>
            <p class="lead text-secondary">
                El <strong>Instituto Provincial de Hemoterapia</strong> es el organismo rector de la hemoterapia en la provincia de San Juan, dependiente del Ministerio de Salud Pública.
            </p>
            <p>
                Nuestra tarea principal es la obtención, procesamiento y distribución de componentes sanguíneos de calidad para todos los hospitales públicos y centros de salud de la provincia. Centralizamos la donación de sangre para optimizar los recursos y asegurar que nunca falte este insumo vital.
            </p>

            <div class="row mt-5">
                <div class="col-md-6 mb-4">
                    <div class="d-flex">
                        <div class="me-3">
                            <i class="bi bi-bullseye text-iphem fs-1"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold">Nuestra Misión</h5>
                            <p class="small text-muted">Asegurar el derecho a la salud mediante la gestión eficiente de la sangre, garantizando el acceso universal y equitativo.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="d-flex">
                        <div class="me-3">
                            <i class="bi bi-eye text-iphem fs-1"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold">Nuestra Visión</h5>
                            <p class="small text-muted">Ser un modelo de referencia nacional en hemoterapia, basado en la donación 100% voluntaria y altruista.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-light py-5">
    <div class="container text-center">
        <h3 class="fw-bold text-dark mb-4">Nuestro Compromiso con la Calidad</h3>
        <div class="row justify-content-center">
            <div class="col-md-3 mb-3">
                <div class="p-3 border rounded bg-white h-100">
                    <i class="bi bi-shield-check text-success fs-2 mb-2"></i>
                    <h6 class="fw-bold">Seguridad Transfusional</h6>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="p-3 border rounded bg-white h-100">
                    <i class="bi bi-people-fill text-primary fs-2 mb-2"></i>
                    <h6 class="fw-bold">Atención Humanizada</h6>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="p-3 border rounded bg-white h-100">
                    <i class="bi bi-gear-fill text-warning fs-2 mb-2"></i>
                    <h6 class="fw-bold">Tecnología de Punta</h6>
                </div>
            </div>
        </div>
    </div>
</div>