@model IEnumerable<iphem_web.Models.Noticia>
@{ ViewData["Title"] = "Inicio"; }

<div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        
        <div class="carousel-item active" style="height: 500px;">
            <div class="d-flex align-items-center justify-content-center h-100 bg-iphem text-white" 
                 style="background: linear-gradient(135deg, var(--sj-rojo) 0%, var(--sj-naranja) 100%);">
                <div class="text-center px-4">
                    <h1 class="display-3 fw-bold mb-3">Donar Sangre es Donar Vida</h1>
                    <p class="lead mb-4 d-none d-md-block">Tu aporte solidario ayuda a salvar miles de vidas en San Juan.</p>
                    <a asp-controller="Turnos" asp-action="Create" class="btn btn-light btn-lg rounded-pill fw-bold px-5 text-iphem shadow hover-scale">
                        SOLICITAR TURNO
                    </a>
                </div>
            </div>
        </div>

        @{ var itemsCarrusel = ViewBag.Carrusel as List<iphem_web.Models.Carrusel>; }

        @if (itemsCarrusel != null)
        {
            @foreach (var slide in itemsCarrusel)
            {
                <div class="carousel-item" style="height: 500px;">
                    @if (!string.IsNullOrEmpty(slide.Enlace))
                    {
                        <a href="@slide.Enlace" target="_blank">
                            <img src="~/img/carrusel/@slide.ImagenPath" class="d-block w-100 h-100" style="object-fit: cover;" alt="Campaña IPHEM">
                        </a>
                    }
                    else
                    {
                        <img src="~/img/carrusel/@slide.ImagenPath" class="d-block w-100 h-100" style="object-fit: cover;" alt="Campaña IPHEM">
                    }
                </div>
            }
        }
    </div>
    
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
    </button>
</div>

<div class="container" style="margin-top: -50px; position: relative; z-index: 10;">
    <div class="row justify-content-center text-center">
        <div class="col-md-3 col-6 mb-3">
            <a asp-controller="Turnos" asp-action="Create" class="card shadow border-0 h-100 py-4 text-decoration-none hover-up">
                <div class="card-body">
                    <i class="bi bi-calendar-check text-iphem fs-1 mb-2"></i>
                    <h5 class="fw-bold text-dark">Sacar Turno</h5>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <a asp-controller="Home" asp-action="Requisitos" class="card shadow border-0 h-100 py-4 text-decoration-none hover-up">
                <div class="card-body">
                    <i class="bi bi-clipboard2-pulse text-iphem fs-1 mb-2"></i>
                    <h5 class="fw-bold text-dark">Requisitos</h5>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <a asp-controller="Home" asp-action="DondeDonar" class="card shadow border-0 h-100 py-4 text-decoration-none hover-up">
                <div class="card-body">
                    <i class="bi bi-geo-alt text-iphem fs-1 mb-2"></i>
                    <h5 class="fw-bold text-dark">Dónde Donar</h5>
                </div>
            </a>
        </div>
    </div>
</div>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h2 class="text-iphem fw-bold mb-0">Últimas Novedades</h2>
        <a asp-controller="Home" asp-action="Novedades" class="btn btn-outline-secondary btn-sm rounded-pill">Ver todas</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    @if (!string.IsNullOrEmpty(item.ImagenPath))
                    {
                        <img src="~/img/noticias/@item.ImagenPath" class="card-img-top" alt="@item.Titulo" style="height: 180px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center text-muted" style="height: 180px;">
                            <i class="bi bi-image fs-1 opacity-25"></i>
                        </div>
                    }
                    
                    <div class="card-body">
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">
                            @item.Fechapublicacion?.ToString("dd MMM yyyy")
                        </small>
                        <h5 class="card-title fw-bold mt-2">
                            <a asp-controller="Home" asp-action="Noticia" asp-route-id="@item.Id" class="text-dark text-decoration-none stretched-link">
                                @item.Titulo
                            </a>
                        </h5>
                        <p class="card-text text-secondary small">
                            @if (item.Cuerpo.Length > 90) { @(item.Cuerpo.Substring(0, 90) + "...") } 
                            else { @item.Cuerpo }
                        </p>
                    </div>
                </div>
            </div>
        }
        
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">No hay noticias cargadas en el sistema.</p>
            </div>
        }
    </div>
</div>

<style>
    .hover-up { transition: transform 0.2s; }
    .hover-up:hover { transform: translateY(-5px); }
</style>