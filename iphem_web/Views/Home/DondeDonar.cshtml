@{ ViewData["Title"] = "Dónde Donar"; }

<div class="container mt-5">
    <div class="row">
        <div class="col-md-5">
            <h2 class="text-iphem fw-bold mb-4">Ubicación IPHEM</h2>
            <p>Nuestra sede central se encuentra equipada para recibir donantes de lunes a sábados.</p>
            
            <div class="d-flex align-items-start mb-4 mt-4">
                <i class="bi bi-geo-alt-fill text-iphem fs-3 me-3"></i>
                <div>
                    <h5 class="fw-bold">Dirección</h5>
                    <p class="mb-0">Rivadavia 728 Este</p>
                    <small class="text-muted">Ciudad de San Juan (Capital)</small>
                </div>
            </div>

            <div class="d-flex align-items-start mb-4">
                <i class="bi bi-clock-fill text-iphem fs-3 me-3"></i>
                <div>
                    <h5 class="fw-bold">Horarios de Atención</h5>
                    <p class="mb-0">Lunes a Viernes: 07:00 a 18:00 hs.</p>
                    <p class="mb-0">Sábados: 08:00 a 12:00 hs.</p>
                </div>
            </div>
            
            <div class="d-flex align-items-start mb-4">
                <i class="bi bi-telephone-fill text-iphem fs-3 me-3"></i>
                <div>
                    <h5 class="fw-bold">Contacto</h5>
                    <p class="mb-0">Tel: 422-3571</p>
                    <p class="mb-0">WhatsApp: 264-1234567</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-7">
            <div class="ratio ratio-4x3 shadow rounded overflow-hidden">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3400.356499691866!2d-68.51347642442657!3d-31.54181997420412!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9681403061053185%3A0xc3f03b57424618e7!2sIPHEM!5e0!3m2!1ses!2sar!4v1706227200000!5m2!1ses!2sar" 
                        style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </div>
</div>